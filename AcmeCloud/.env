OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Vector DB / knowledge base paths
CHROMA_DIR=./vector_store
KB_DIR=./data/kb

# Audit logs
AUDIT_LOG_FILE=./logs/audit.log

# Support routing
SUPPORT_EMAIL_DL=support@acmecloudsupport.com

# ServiceNow (dummy by default)
SERVICENOW_INSTANCE=https://acmecloud.servicenow.com
SERVICENOW_USERNAME=dummy_user
SERVICENOW_PASSWORD=dummy_password

# Keep false for local demo; set true only when real endpoint is reachable
ENABLE_EXTERNAL_TOOL_CALLS=false

# IMAP inbound email polling
IMAP_HOST=imap.yourmailserver.com
IMAP_PORT=993
IMAP_USERNAME=support@acmecloudsupport.com
IMAP_PASSWORD=
IMAP_FOLDER=INBOX
IMAP_POLL_LIMIT=10
